#pragma config(Sensor, port1,  distanceSensor,  sensorVexIQ_Distance)
#pragma config(Sensor, port2,  colorSensor,     sensorVexIQ_ColorHue)
#pragma config(Sensor, port5,  gyroSensor,      sensorVexIQ_Gyro)
#pragma config(Sensor, port6,  touchLED,        sensorVexIQ_LED)
#pragma config(Sensor, port7,  touchLED2,       sensorVexIQ_LED)
#pragma config(Sensor, port9,  leftRearBumper,  sensorVexIQ_Touch)
#pragma config(Sensor, port10, rightRearBumper, sensorVexIQ_Touch)
#pragma config(Motor,  motor3, leftMotor,       tmotorVexIQ, PIDControl, driveLeft,  encoder)
#pragma config(Motor,  motor4, rightMotor,      tmotorVexIQ, PIDControl, reversed, driveRight, encoder)
#pragma config(Motor,  motor11,handMotor,       tmotorVexIQ, PIDControl, encoder)
#pragma config(Motor,  motor8, clawMotor,       tmotorVexIQ, PIDControl, encoder)
//*!!Code automatically generated by 'ROBOTC' configuration wizard               !!*//

// ----------------- НАСТРОЙКИ -----------------
const int DRIVE_SPEED          = 50;   // скорость движения вперёд
const int TURN_SPEED           = 40;   // скорость поворота / объезда
const int ARM_UP_POWER         = 60;   // подъём руки
const int ARM_DOWN_POWER       = -40;  // опускание руки
// Для клешни направление оказалось обратным: чтобы сжать, нужен один знак,
// чтобы разжать — противоположный, поэтому меняем знаки местами.
const int CLAW_CLOSE_POWER     = -60;  // закрытие клешни
const int CLAW_OPEN_POWER      = 60;   // открытие клешни

// Ограничение по времени движения, чтобы не "зависнуть" в цикле,
// если механизм упёрся в механический ограничитель раньше целевой позиции.
// Делаем ещё больший запас по времени, чтобы рука успевала дойти до -1000.
const int ARM_MOVE_TIMEOUT_MS  = 4000;
const int CLAW_MOVE_TIMEOUT_MS = 2000;

// Цвета второго touchLED (порт7) — индикатор состояния
// RobotC: используем тип short, т.к. TVexIQLEDColor может быть недоступен в вашей версии.
const short STATUS_FREE_COLOR     = colorGreen;   // свободное движение
const short STATUS_ARM_DOWN_COLOR = colorBlue;    // опускание руки
const short STATUS_ARM_UP_COLOR   = colorYellow;  // поднятие руки
const short STATUS_AVOID_COLOR    = colorOrange;  // объезд препятствия (вместо colorPurple)
const short STATUS_BUMP_COLOR     = colorRed;     // удар бампером при движении назад

// Дистанции (датчик расстояния VEX IQ обычно даёт мм или см, подбираем опытно)
// Мелкое препятствие: от 5 до 15 см.
// Крупное препятствие: не раньше чем за 25 см.
const int SMALL_OBJ_MIN_MM     = 50;   // 5 см
const int SMALL_OBJ_MAX_MM     = 150;  // 15 см считаем мелким объектом для захвата
const int WALL_DISTANCE_MM     = 250;  // крупное препятствие ближе/равно 25 см

// Положение руки/клешни по энкодеру:
// Старт: рука максимально поднята и лежит на кузове, клешня разжата.
// В начале программы это положение принимаем за 0 (resetMotorEncoder).
const int ARM_UP_POS           = 0;     // исходное положение руки (максимально вверх, на кузове)
// Опускаем руку глубже; по факту испытаний механического упора ещё нет.
const int ARM_DOWN_POS         = -1100; // рука опускается к объекту (длинный ход вниз)
// Клешня: стартуем из полностью разжатого положения и сбрасываем энкодер в 0.
// При закрытии поворачиваем примерно на 200 "градусов"/кликов в ОТРИЦАТЕЛЬНУЮ сторону.
const int CLAW_CLOSED_POS      = -200;  // клешня зажата (~200 градусов хода)
const int CLAW_OPEN_POS        = 0;     // клешня полностью открыта (стартовое положение)

// ----------------- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ -----------------

void stopDrive() {
    motor[leftMotor]  = 0;
    motor[rightMotor] = 0;
}

void setStatusColor(short c) {
    setTouchLEDColor(touchLED2, c);
}

void driveForward(int power) {
    motor[leftMotor]  = power;
    motor[rightMotor] = power;
}

void driveBackward(int power) {
    motor[leftMotor]  = -power;
    motor[rightMotor] = -power;
}

// Прототипы (RobotC требует объявление до использования)
bool rearBumped();

void moveArmTo(int targetPos, int powerUp, int powerDown) {
    // Управление по энкодеру с ограничением по времени,
    // чтобы не зависнуть, если рука упрётся в механический ограничитель.
    clearTimer(T1);
    while (abs(getMotorEncoder(handMotor) - targetPos) > 5 &&
           time1[T1] < ARM_MOVE_TIMEOUT_MS) {
        if (getMotorEncoder(handMotor) < targetPos) {
            motor[handMotor] = powerUp;
        } else {
            motor[handMotor] = powerDown;
        }
    }
    motor[handMotor] = 0;
}

void moveClawTo(int targetPos, int powerClose, int powerOpen) {
    clearTimer(T2);
    while (abs(getMotorEncoder(clawMotor) - targetPos) > 5 &&
           time1[T2] < CLAW_MOVE_TIMEOUT_MS) {
        // Базовая логика: если текущая позиция МЕНЬШЕ целевой — крутим в одну сторону,
        // если БОЛЬШЕ — в другую. Конкретное направление задаётся через параметры.
        if (getMotorEncoder(clawMotor) < targetPos) {
            motor[clawMotor] = powerClose;
        } else {
            motor[clawMotor] = powerOpen;
        }
    }
    motor[clawMotor] = 0;
}

// Поднять руку и открыть клешню (режим поиска)
void setSearchPose() {
    moveArmTo(ARM_UP_POS, ARM_UP_POWER, ARM_DOWN_POWER);
    // Для открытия клешни нам нужно инвертировать направления:
    // передаём "открывающее" направление в параметр powerClose, чтобы логика в moveClawTo
    // вела мотор в сторону открытия.
    moveClawTo(CLAW_OPEN_POS, CLAW_OPEN_POWER, CLAW_CLOSE_POWER);
}

// Опустить руку, захватить и поднять объект
void grabObjectSequence() {
    stopDrive();

    // 1. Опустить руку на 200 градусов вниз к объекту
    setStatusColor(STATUS_ARM_DOWN_COLOR);
    moveArmTo(ARM_DOWN_POS, ARM_UP_POWER, ARM_DOWN_POWER);
    wait1Msec(200);

    // 2. Сжать клешню и захватить предмет
    moveClawTo(CLAW_CLOSED_POS, CLAW_CLOSE_POWER, CLAW_OPEN_POWER);
    wait1Msec(200);

    // 3. Поднять руку обратно на 200 градусов в исходное положение
    setStatusColor(STATUS_ARM_UP_COLOR);
    moveArmTo(ARM_UP_POS, ARM_UP_POWER, ARM_DOWN_POWER);
    wait1Msec(200);

    // 4. Разжать клешню над кузовом — предмет падает в кузов
    moveClawTo(CLAW_OPEN_POS, CLAW_OPEN_POWER, CLAW_CLOSE_POWER);
    setStatusColor(STATUS_FREE_COLOR);
}

// Объезд крупного препятствия
// Алгоритм: немного сдаём назад, затем едем ВПЕРЁД по дуге,
// всегда поворачивая в одну сторону (вправо).
void avoidObstacle() {
    stopDrive();
    setStatusColor(STATUS_AVOID_COLOR);

    // Отъехать немного дальше назад, чтобы отдалиться от стены/препятствия
    driveBackward(40);
    // Если при движении назад задели бампером — показываем отдельный цвет
    if (rearBumped()) setStatusColor(STATUS_BUMP_COLOR);
    wait1Msec(700);  // было 400 мс
    stopDrive();
    setStatusColor(STATUS_AVOID_COLOR);

    // Едем вперёд по более резкой дуге вправо: левый мотор быстрее, правый намного медленнее.
    motor[leftMotor]  = TURN_SPEED;
    motor[rightMotor] = TURN_SPEED / 5;  // было /3, теперь поворот резче
    wait1Msec(1000);   // чуть дольше для полного разворота
    stopDrive();
    setStatusColor(STATUS_FREE_COLOR);
}

// Быстрая проверка на нажатие бамперов
bool rearBumped() {
    return (SensorValue[leftRearBumper] == 1 || SensorValue[rightRearBumper] == 1);
}

// ----------------- ОСНОВНАЯ ПРОГРАММА -----------------

task main() {
    // Сброс энкодеров руки/клешни (по положению при старте)
    resetMotorEncoder(handMotor);
    resetMotorEncoder(clawMotor); // в этот момент клешня должна быть полностью открыта
    SensorValue[gyroSensor] = 0;

    // Стартовая поза: рука поднята, клешня открыта
    setSearchPose();

    // Переменные для управления паузой по touchLED
    bool isPaused = false;
    int  lastTouchState = 0;

    // При старте LED выключен
    setTouchLEDColor(touchLED, colorNone);
    setStatusColor(STATUS_FREE_COLOR);

    while (true) {
        int dist = SensorValue[distanceSensor]; // мм или см (в зависимости от прошивки)
        int touchState = SensorValue[touchLED]; // 0 или 1

        // Обработка нажатия на сенсорный светодиод как кнопки-переключателя
        // Фиксируем только переход 0 -> 1 (первое касание)
        if (touchState == 1 && lastTouchState == 0) {
            isPaused = !isPaused;   // переключаем состояние: пауза / движение

            // В режиме паузы LED горит, в режиме движения гаснет
            if (isPaused) {
                setTouchLEDColor(touchLED, colorRed);
            } else {
                setTouchLEDColor(touchLED, colorNone);
            }
        }
        lastTouchState = touchState;

        // Если режим паузы включён — стоим на месте и пропускаем остальную логику
        if (isPaused) {
            stopDrive();
            wait1Msec(20);
            continue;
        }

        // Если рукой/клешнёй задели что-то сзади — немного вперёд и объезд
        if (rearBumped()) {
            // Удар бампером при движении назад здесь не отслеживаем (мы едем вперёд),
            // но сам факт удара подсветим как предупреждение на секунду.
            setStatusColor(STATUS_BUMP_COLOR);
            driveForward(40);
            wait1Msec(500);
            stopDrive();
            avoidObstacle();
        }

        // Маленький объект в диапазоне 5–10 см
        else if (dist >= SMALL_OBJ_MIN_MM && dist <= SMALL_OBJ_MAX_MM) {
            grabObjectSequence();
            setSearchPose(); // вернуться к поиску
        }

        // Крупное препятствие / стена ближе заданного расстояния
        else if (dist > 0 && dist < WALL_DISTANCE_MM) {
            avoidObstacle();
            setSearchPose();
        }

        // Всё свободно — едем вперёд, рука должна быть поднята
        else {
            setStatusColor(STATUS_FREE_COLOR);
            // гарантируем, что рука поднята (если вдруг была не в том положении)
            if (abs(getMotorEncoder(handMotor) - ARM_UP_POS) > 20) {
                moveArmTo(ARM_UP_POS, ARM_UP_POWER, ARM_DOWN_POWER);
            }
            driveForward(DRIVE_SPEED);
        }

        wait1Msec(50); // небольшая пауза, чтобы не перегружать цикл
    }
}

