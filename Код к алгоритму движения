1. Код к алгоритму движения робота
#pragma config(Sensor, port1,  distanceSensor, sensorVexIQ_Distance)
#pragma config(Sensor, port5,  gyroSensor,     sensorVexIQ_Gyro)
#pragma config(Sensor, port2,  colorSensor,    sensorVexIQ_ColorHue)
#pragma config(Sensor, port6,  touchLED,       sensorVexIQ_LED)
#pragma config(Sensor, port9,  leftRearBumper, sensorVexIQ_Touch)
#pragma config(Sensor, port10, rightRearBumper, sensorVexIQ_Touch)
#pragma config(Motor,  motor3, leftMotor,     tmotorVexIQ, PIDControl, driveLeft, encoder)
#pragma config(Motor,  motor4, rightMotor,    tmotorVexIQ, PIDControl, driveRight, reversed, encoder)
//*!!Code automatically generated by 'ROBOTC' configuration wizard               !!*//
const int FORWARD_SPEED = 40;
const int BACKWARD_SPEED = -30;
const int TURN_SPEED = 30;
const int SAFE_DISTANCE = 100;
const int BACKWARD_TIME = 400;
const int TURN_TIME = 600;
const int STATE_FORWARD = 0;
const int STATE_BACKWARD = 1;
const int STATE_TURN = 2;
const int STATE_EMERGENCY = 3;
int currentState = STATE_FORWARD;
long stateStartTime = 0;
bool turningRight = true;
int obstacleCount = 0;
void initializeRobot() {
resetMotorEncoder(leftMotor);
resetMotorEncoder(rightMotor);
setTouchLEDColor(touchLED, colorGreen);
}
bool obstacleDetected() {
int distance = SensorValue[distanceSensor];
if (distance < 0 || distance > 2000) return false;
return (distance > 0 && distance < SAFE_DISTANCE);
}
bool rearBumperPressed() {
return (SensorValue[leftRearBumper] || SensorValue[rightRearBumper]);
}
void moveForward() {
setMotorSpeed(leftMotor, FORWARD_SPEED);
setMotorSpeed(rightMotor, FORWARD_SPEED);
}
void moveBackward() {
setMotorSpeed(leftMotor, BACKWARD_SPEED);
setMotorSpeed(rightMotor, BACKWARD_SPEED);
}
void turn() {
if (turningRight) {
setMotorSpeed(leftMotor, TURN_SPEED);
setMotorSpeed(rightMotor, -TURN_SPEED);
} else {
setMotorSpeed(leftMotor, -TURN_SPEED);
setMotorSpeed(rightMotor, TURN_SPEED);
}
}
void stopRobot() {
setMotorSpeed(leftMotor, 0);
setMotorSpeed(rightMotor, 0);
}
void emergencyStop() {
stopRobot();
setTouchLEDColor(touchLED, colorRed);
currentState = STATE_EMERGENCY;
}
task autonomousNavigation() {
initializeRobot();
stateStartTime = nPgmTime;
while(true) {
if(SensorValue[touchLED] == 1) {
emergencyStop();
return;
}
if ((nPgmTime % 2000) < 50) {
writeDebugStream("State: %d, Distance: %d, Obstacles: %d\n",
currentState, SensorValue[distanceSensor], obstacleCount);
}
switch(currentState) {
case STATE_FORWARD:
if(obstacleDetected()) {
obstacleCount++;
stopRobot();
currentState = STATE_BACKWARD;
stateStartTime = nPgmTime;
if (obstacleCount % 2 == 0) {
turningRight = !turningRight;
}
if (obstacleCount > 3) {
turningRight = !turningRight;
obstacleCount = 0;
}
} else {
obstacleCount = 0;
moveForward();
}
break;
case STATE_BACKWARD:
moveBackward();
if(rearBumperPressed()) {
turningRight = !turningRight;
stopRobot();
currentState = STATE_TURN;
stateStartTime = nPgmTime;
}
else if(nPgmTime - stateStartTime > BACKWARD_TIME) {
stopRobot();
currentState = STATE_TURN;
stateStartTime = nPgmTime;
}
break;
case STATE_TURN:
turn();
if(nPgmTime - stateStartTime > TURN_TIME) {
stopRobot();
currentState = STATE_FORWARD;
stateStartTime = nPgmTime;
}
break;
case STATE_EMERGENCY:
stopRobot();
break;
}
switch(currentState) {
case STATE_FORWARD: setTouchLEDColor(touchLED, colorGreen); break;
case STATE_BACKWARD:
case STATE_TURN: setTouchLEDColor(touchLED, colorOrange); break;
case STATE_EMERGENCY: setTouchLEDColor(touchLED, colorRed); break;
}
wait1Msec(20);
}
}
task main() {
startTask(autonomousNavigation);
while(true) {
wait1Msec(100);
}
}
